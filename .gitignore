# Standard .gitignore for general projects

# OS
.DS_Store
Thumbs.db
desktop.ini

#used in icebreaker: .DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

#used in icebreaker:

# Runtime / pid files / temp
tmp/
temp/
*.pid
*.seed
*.pid.lock

#used in icebreaker: /tmp


# Environment files
.env
.env.local
.env.*.local
.env.test
.env.production

#used in icebreaker: .env

# Node
node_modules/
dist/
build/
.cache/
.npm/
.yarn/*
!.yarn/patches
.pnp.*
coverage/

#used in icebreaker: node_modules/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.venv/
pip-wheel-metadata/
*.egg-info/
.eggs/
.pytest_cache/

#used in icebreaker: 

