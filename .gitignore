# Standard .gitignore for general projects

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime / pid files / temp
tmp/
temp/
*.pid
*.seed
*.pid.lock

# Environment files
.env
.env.local
.env.*.local
.env.test
.env.production

# Node
node_modules/
dist/
build/
.cache/
.npm/
.yarn/*
!.yarn/patches
.pnp.*
coverage/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.venv/
pip-wheel-metadata/
*.egg-info/
.eggs/
.pytest_cache/

# Java / JVM
*.class
*.jar
*.war
*.ear
target/

# Go / binaries
bin/
*.exe
*.dll
*.so
*.dylib

# Rust
target/

# Ruby
*.gem
*.rbc
.bundle/
vendor/bundle/
log/
tmp/

# PHP / Composer
vendor/
composer.lock

# Build artifacts
build/
dist/
out/
coverage/

# IDEs and editors
.vscode/
.idea/
*.sublime-*
*.code-workspace
*.swp

# Containers / orchestrators
Dockerfile.*
docker-compose.override.yml
.docker/
.kube/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
crash.log
override.tfvars

# SSH / credentials / keys
*.pem
*.key
known_hosts
secrets.*
credentials

# Archives and packages
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Misc
*.log
*.bak
*.tmp
*.old



#custom additions for ICEbreaker
private/database/
idea.txt
auth.txt
public/imgs/source-examples/
ICEBreaker_Architecture.png